# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=melotech

# Backend (Docker: postgres/redis resolved via service names on melotech network)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/melotech
REDIS_URL=redis://redis:6379

# OpenAI — Structured Outputs require gpt-5.4 or newer
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4

# Server
PORT=3001
NODE_ENV=development

# CORS (optional; omit to allow all origins in dev)
# FRONTEND_URL=https://your-frontend.railway.app
