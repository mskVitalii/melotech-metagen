# =====================================================================
# Melotech Metagen — Root .env.example
# All environment variables used across backend and frontend services
# Each service has its own .env file in its directory.
# =====================================================================

# --- Backend (backend/.env) ---

# Database (Railway PostgreSQL add-on — append ?sslmode=require for Railway)
DATABASE_URL=postgresql://postgres:password@localhost:5432/melotech

# Redis (Railway Redis add-on)
REDIS_URL=redis://localhost:6379

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-2024-08-06

# Server
PORT=3001
NODE_ENV=production

# Frontend URL for CORS (set in Railway dashboard; omit for dev to allow all origins)
FRONTEND_URL=https://your-frontend.railway.app

# --- Frontend (frontend/.env.local) ---

# Backend API URL for server-side fetching
NEXT_PUBLIC_API_URL=http://localhost:3001
